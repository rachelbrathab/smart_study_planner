{
  "manifest_version": 3,
  "name": "Smart Study Focus Enforcement (Local)",
  "description": "Blocks distracting websites while study sessions are active.",
  "version": "1.0.1",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "alarms",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Focus Mode"
  },
  "icons": {
    "128": "icons/icon.png"
  }
}
